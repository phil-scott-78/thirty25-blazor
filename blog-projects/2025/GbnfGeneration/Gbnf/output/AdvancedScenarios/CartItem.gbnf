root ::= "{" space root-productid-kv "," space root-productname-kv "," space root-quantity-kv "," space root-price-kv "}" space
char ::= [^"\\\x7F\x00-\x1F\u27E8\u27E9] | [\\] (["\\bfnrt] | "u" [0-9a-fA-F]{4})
space ::= | " " | "\n" [ \t]{0,20}
root-productid-kv ::= "\"ProductId\"" space ":" space "\"" char{1, 512} "\"" space
root-productname-kv ::= "\"ProductName\"" space ":" space "\"" char{1, 512} "\"" space
root-quantity-kv ::= "\"Quantity\"" space ":" space ("-"? [0] | [1-9] [0-9]{0,15}) space
root-price-kv ::= "\"Price\"" space ":" space ("-"? ([0] | [1-9] [0-9]{0,15}) ("." [0-9]{1,15})?) space